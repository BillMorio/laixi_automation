# ============================================================================
# SECRETS — NEVER commit
# ============================================================================
.env
.env.*
!.env.example

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/

# ============================================================================
# Runtime working directories (regenerated on each run)
# ============================================================================
logs/
screenshots/
uploads/

# ============================================================================
# Local backups
# ============================================================================
backups/

# ============================================================================
# Atomic-write artifacts (.env.tmp, etc.)
# ============================================================================
*.tmp
*.bak

# ============================================================================
# Stray screenshots at the repo root (screenshots/ is already ignored above)
# ============================================================================
*.png

# ============================================================================
# IDE / OS
# ============================================================================
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db
desktop.ini
